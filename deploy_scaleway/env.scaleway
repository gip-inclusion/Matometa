# Matometa — Scaleway deployment environment
# Copy to .env on the server. Tokens are filled by setup_expert_test.sh.

# =============================================================================
# Core
# =============================================================================

AGENT_BACKEND=cli
WEB_HOST=0.0.0.0
WEB_PORT=5000
WEB_DEBUG=false

ADMIN_USERS=admin@matometa.dev
DEFAULT_USER=admin@matometa.dev

# =============================================================================
# Claude Code CLI
# =============================================================================

# OAuth token (required — paste from your Claude Code auth)
# CLAUDE_CODE_OAUTH_TOKEN=your-oauth-token
CLAUDE_CODE_DISABLE_AUTO_MEMORY=1

# =============================================================================
# Data Sources (fill in what you need)
# =============================================================================

# MATOMO_API_KEY=
# METABASE_STATS_API_KEY=
# METABASE_DATALAKE_API_KEY=

# =============================================================================
# Expert Mode — Gitea + Coolify (filled by setup_expert_test.sh)
# =============================================================================

GITEA_URL=http://host.docker.internal:3300
GITEA_PUBLIC_URL=http://${EXPERT_DEPLOY_PUBLIC_HOST}:3300
GITEA_ORG=apps
# GITEA_API_TOKEN=  (auto-generated by setup script)

COOLIFY_URL=http://host.docker.internal:8001
# COOLIFY_API_TOKEN=  (auto-generated by setup script)
COOLIFY_INTERNAL_URL=http://coolify:8080

# EXPERT_DEPLOY_PUBLIC_HOST=  (set to server public IP)

# Admin credentials for Gitea + Coolify (used by setup script)
EXPERT_ADMIN_USER=matometa
EXPERT_ADMIN_EMAIL=admin@matometa.dev
# EXPERT_ADMIN_PASS=  (auto-generated by setup script if unset)

# =============================================================================
# Coolify internals (defaults are fine for dev)
# =============================================================================

COOLIFY_DB_PASSWORD=coolify-dev-password
COOLIFY_REDIS_PASSWORD=coolify-redis-dev
